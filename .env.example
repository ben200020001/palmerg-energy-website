# Copy to `.env` and fill in values. `.env` is gitignored.

## Express API (server/)
PORT=5174

## OpenAI (for /api/search)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

## Resend (for /api/contact)
# Domain must be verified in Resend for production sender/recipient
RESEND_API_KEY=
CONTACT_TO=info@palmergenergy.com
CONTACT_FROM="Palmerg Energy Contact Form <info@palmergenergy.com>"
