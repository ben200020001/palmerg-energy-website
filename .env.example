# Copy to `.env` and fill in values. `.env` is gitignored.

## Express API (server/)
PORT=5174

## OpenAI (for /api/search)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

## Google reCAPTCHA v3 (contact form)
# Create a v3 key pair at https://www.google.com/recaptcha/admin — add domain(s) e.g. localhost, palmergenergy.com
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional; default 0.5 (v3 score 0.0–1.0)
# RECAPTCHA_MIN_SCORE=0.5
# Domain must be verified in Resend for production sender/recipient
RESEND_API_KEY=
CONTACT_TO=info@palmergenergy.com
CONTACT_FROM="Palmerg Energy Contact Form <info@palmergenergy.com>"
